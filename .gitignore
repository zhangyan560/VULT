# Obsidian 缓存与自动生成文件
.obsidian/cache/
.obsidian/sync.json
.obsidian/workspace.json
.obsidian/appearance.json
.obsidian/app.json
.obsidian/hotkeys.json

# 保留 plugins/ 目录结构和 Git 插件配置
# .obsidian/plugins/ 整个忽略，除了 obsidian-git
.obsidian/plugins/*
!.obsidian/plugins/obsidian-git/
.obsidian/plugins/obsidian-git/*
!.obsidian/plugins/obsidian-git/manifest.json
!.obsidian/plugins/obsidian-git/data.json

# 保留社区插件列表
!.obsidian/community-plugins.json

# 系统文件
.DS_Store
Thumbs.db
.dropbox

# 敏感信息
.env
.env.local
*.key
*.pem
credentials.json
secrets.json

# 临时文件
*.tmp
*.log
*.swp
*~

# IDE
.vscode/
.idea/

# Node/其他包管理
node_modules/
.npm
package-lock.json
yarn.lock
